#!/bin/bash

# shellcheck source=start-utils
. "$(dirname "$0")/start-utils"

: "${GIT_BACKUP_ENABLED:=false}"
: "${GIT_BACKUP_PATH:=/data}"
: "${GIT_BACKUP_TRIGGERS:=}"
: "${GIT_BACKUP_PERIOD:=0}"
: "${GIT_BACKUP_COMMIT_MSG:=Auto backup - %DATE%}"
: "${GIT_BACKUP_BRANCH:=}"
: "${GIT_BACKUP_ADD_PATHS:=.}"
: "${GIT_BACKUP_EXCLUDE_PATHS:=}"
: "${GIT_BACKUP_AUTHOR_NAME:=Minecraft Server}"
: "${GIT_BACKUP_AUTHOR_EMAIL:=minecraft@server.local}"
: "${GIT_BACKUP_LFS_ENABLED:=false}"
: "${GIT_BACKUP_LFS_PATTERNS:=*.mca,*.jar,*.zip,*.dat,*.dat_old,*.nbt,*.sqlite,*.sqlite-shm,*.sqlite-wal}"
: "${GIT_BACKUP_PUSH_ENABLED:=false}"
: "${GIT_BACKUP_REMOTE:=}"
: "${GIT_BACKUP_REMOTE_NAME:=origin}"
: "${GIT_BACKUP_INIT_MODE:=}"
: "${GIT_BACKUP_RESTORE_ENABLED:=false}"
: "${GIT_BACKUP_RESTORE_TARGET:=}"
: "${GIT_BACKUP_GITIGNORE_ENABLED:=true}"
: "${GIT_BACKUP_GITIGNORE_PATTERNS:=logs/,crash-reports/,cache/,bluemap/,libraries/,plugins/spark/,.ssh/}"
: "${GIT_BACKUP_SSH_KEYGEN:=true}"
: "${GIT_BACKUP_SSH_KEY_PATH:=${GIT_BACKUP_PATH}/.ssh}"
: "${GIT_BACKUP_SSH_WAIT_TIMEOUT:=300}"
: "${GIT_BACKUP_SSH_RETRY_INTERVAL:=10}"
: "${SERVER_PORT:=25565}"

export GIT_BACKUP_ENABLED
export GIT_BACKUP_PATH
export GIT_BACKUP_TRIGGERS
export GIT_BACKUP_PERIOD
export GIT_BACKUP_COMMIT_MSG
export GIT_BACKUP_BRANCH
export GIT_BACKUP_ADD_PATHS
export GIT_BACKUP_EXCLUDE_PATHS
export GIT_BACKUP_AUTHOR_NAME
export GIT_BACKUP_AUTHOR_EMAIL
export GIT_BACKUP_LFS_ENABLED
export GIT_BACKUP_LFS_PATTERNS
export GIT_BACKUP_PUSH_ENABLED
export GIT_BACKUP_REMOTE
export GIT_BACKUP_REMOTE_NAME
export GIT_BACKUP_INIT_MODE
export GIT_BACKUP_RESTORE_ENABLED
export GIT_BACKUP_RESTORE_TARGET
export GIT_BACKUP_GITIGNORE_ENABLED
export GIT_BACKUP_GITIGNORE_PATTERNS
export GIT_BACKUP_SSH_KEYGEN
export GIT_BACKUP_SSH_KEY_PATH
export GIT_BACKUP_SSH_WAIT_TIMEOUT
export GIT_BACKUP_SSH_RETRY_INTERVAL
export SERVER_PORT

if ! isTrue "${GIT_BACKUP_ENABLED}"; then
  exit 0
fi

log "Git backup functionality enabled"

isDebugging && set -x

isNumericElseSetToDefault GIT_BACKUP_PERIOD 0

# Helper function to check if remote URL uses SSH
is_ssh_remote() {
  local url="$1"
  [[ "$url" =~ ^git@ ]] || [[ "$url" =~ ^ssh:// ]]
}

# Determine if we need blocking initialization:
# - clone mode: always blocking (need to fetch files before server starts)
# - restore enabled: always blocking (need to restore files before server starts)
# - init mode with push enabled and SSH remote: blocking (need to wait for deploy key)
needs_blocking_init=false

if [[ "${GIT_BACKUP_INIT_MODE,,}" == "clone" ]]; then
  needs_blocking_init=true
  log "Blocking init required: clone mode"
elif isTrue "${GIT_BACKUP_RESTORE_ENABLED}"; then
  needs_blocking_init=true
  log "Blocking init required: restore enabled"
elif [[ "${GIT_BACKUP_INIT_MODE,,}" == "init" ]] && isTrue "${GIT_BACKUP_PUSH_ENABLED}" && is_ssh_remote "${GIT_BACKUP_REMOTE}"; then
  needs_blocking_init=true
  log "Blocking init required: init mode with SSH push (waiting for deploy key)"
fi

if [[ "$needs_blocking_init" == "true" ]]; then
  log "Running Git backup initialization (blocking)..."

  # Run the init script which handles clone, restore, and initial setup
  # This runs BLOCKING to ensure files are restored/SSH is configured before server continues
  if "$(dirname "$0")/auto/git-backup-init.sh"; then
    log "Git backup initialization completed successfully"
    # Mark that init is complete so daemon skips redundant init
    GIT_BACKUP_INIT_COMPLETE="true"
  else
    log "WARNING: Git backup initialization had errors, check logs above"
    GIT_BACKUP_INIT_COMPLETE="false"
  fi
  export GIT_BACKUP_INIT_COMPLETE
fi

# Start the daemon in background for ongoing backup operations
"$(dirname "$0")/auto/git-backup-daemon.sh" &
